```typescript
// Install Plaid SDK
npm install react-plaid-link

import { usePlaidLink } from 'react-plaid-link';

function PlaidLinkButton({ userId, partnerRole }) {
  const [linkToken, setLinkToken] = useState(null);
  
  useEffect(() => {
    // Create link token
    fetch('https://your-project.supabase.co/functions/v1/make-server-8c22500c/financial/plaid-create-token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, partnerRole })
    })
    .then(res => res.json())
    .then(data => setLinkToken(data.linkToken));
  }, []);
  
  const { open, ready } = usePlaidLink({
    token: linkToken,
    onSuccess: async (publicToken) => {
      // Exchange token
      await fetch(
        'https://your-project.supabase.co/functions/v1/make-server-8c22500c/financial/plaid-exchange-token',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, partnerRole, publicToken })
        }
      );
      
      alert('Bank account connected!');
    }
  });
  
  return <button onClick={() => open()} disabled={!ready}>Connect Bank</button>;
}
```

