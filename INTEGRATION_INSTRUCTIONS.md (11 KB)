## Step 6: Frontend Integration

### For Stripe Financial Connections

```typescript
// Install Stripe SDK
npm install @stripe/stripe-js

// Create component
import { loadStripe } from '@stripe/stripe-js';

async function connectBankAccount(userId: string, partnerRole: 'person1' | 'person2') {
  // 1. Create session
  const response = await fetch(
    'https://your-project.supabase.co/functions/v1/make-server-8c22500c/financial/stripe-create-session',
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, partnerRole })
    }
  );
  
  const { clientSecret } = await response.json();
  
  // 2. Open Stripe Financial Connections
  const stripe = await loadStripe('pk_test_your_publishable_key');
  const result = await stripe.collectFinancialConnectionsAccounts({
    clientSecret
  });
  
  // 3. Save connected accounts
  const accountIds = result.financialConnectionsSession.accounts.map(a => a.id);
  
  await fetch(
    'https://your-project.supabase.co/functions/v1/make-server-8c22500c/financial/stripe-save-accounts',
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, partnerRole, accountIds })
    }
  );
  
  alert('Bank account connected!');
}
```

