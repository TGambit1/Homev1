// Step 1: Create Stripe Financial Connections session
app.post('/make-server-8c22500c/financial/stripe-create-session', async (c) => {
  try {
    const { userId, partnerRole } = await c.req.json();
    
    if (!userId) {
      return c.json({ error: 'User ID required' }, 400);
    }
    
    if (!STRIPE_SECRET_KEY) {
      return c.json({ error: 'Stripe not configured' }, 500);
    }

    // Get user details for Stripe customer
    const user = await db.getUserById(userId);
    if (!user) {
      return c.json({ error: 'User not found' }, 404);
    }

    // Determine which partner's email to use
    const email = partnerRole === 'person2' ? user.secondary_email : user.primary_email;
    const name = partnerRole === 'person2' ? user.person2_name : user.person1_name;

    // Create or retrieve Stripe customer
    const customerId = await getOrCreateStripeCustomer(userId, email, name);

    // Create Financial Connections Session
    const sessionResponse = await fetch('https://api.stripe.com/v1/financial_connections/sessions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${STRIPE_SECRET_KEY}`,
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      body: new URLSearchParams({
        'account_holder[type]': 'customer',
        'account_holder[customer]': customerId,
        'permissions[]': 'balances',
        'permissions[]': 'transactions',
        'permissions[]': 'ownership',
        'filters[countries][]': 'US',
      }),
    });

    const session = await sessionResponse.json();

    if (!sessionResponse.ok) {
      console.error('Stripe session error:', session);
      return c.json({ error: 'Failed to create session', details: session }, 400);
    }

    // Store session in database
    await db.saveFinancialLinkSession({
      user_id: userId,
      partner_role: partnerRole || 'person1',
      provider: 'stripe',
      provider_session_token: session.client_secret,
      requested_permissions: ['balances', 'transactions', 'ownership'],
    });

    return c.json({
      success: true,
      clientSecret: session.client_secret,
      sessionId: session.id,
    });
  } catch (error) {
    console.error('Error creating Stripe session:', error);
    return c.json({ error: 'Failed to create session', details: error.message }, 500);
  }
});

// Helper function to get or create Stripe customer
async function getOrCreateStripeCustomer(
  userId: string,
  email: string,
  name: string
): Promise<string> {
  // First check if customer already exists in KV store
  const existingCustomerId = await db.getStripeCustomerId(userId);
  if (existingCustomerId) {
    return existingCustomerId;
  }

  // Create new Stripe customer
  const customerResponse = await fetch('https://api.stripe.com/v1/customers', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${STRIPE_SECRET_KEY}`,
      'Content-Type': 'application/x-www-form-urlencoded',
    },
    body: new URLSearchParams({
      email,
      name,
      'metadata[user_id]': userId,
    }),
  });

  const customer = await customerResponse.json();
  
  if (!customerResponse.ok) {
    throw new Error(`Failed to create Stripe customer: ${customer.error?.message}`);
  }

  // Store customer ID for future use
  await db.saveStripeCustomerId(userId, customer.id);

  return customer.id;
}

// Step 2: Save connected accounts after user completes flow
app.post('/make-server-8c22500c/financial/stripe-save-accounts', async (c) => {
  try {
    const { userId, partnerRole, accountIds } = await c.req.json();

    if (!userId || !accountIds || !Array.isArray(accountIds)) {
      return c.json({ error: 'Invalid request parameters' }, 400);
    }

    const savedAccounts = [];

    // Fetch details and save each account
    for (const accountId of accountIds) {
      const accountResponse = await fetch(
        `https://api.stripe.com/v1/financial_connections/accounts/${accountId}`,
        {
          headers: {
            'Authorization': `Bearer ${STRIPE_SECRET_KEY}`,
          },
        }
      );

      const account = await accountResponse.json();

      if (!accountResponse.ok) {
        console.error('Error fetching account:', account);
        continue;
      }

      // Save to database
      const savedAccount = await db.saveLinkedAccount({
        user_id: userId,
        partner_role: partnerRole || 'person1',
        provider: 'stripe',
        external_account_id: account.id,
        display_name: account.display_name || account.institution_name,
        institution_name: account.institution_name,
        last_four_digits: account.last4,
        category: account.category,
        subcategory: account.subcategory,
        connection_state: 'active',
        granted_permissions: account.permissions || [],
        supports_ach_payments: account.category === 'depository',
      });

      // Subscribe to balance updates
      if (account.permissions?.includes('balances')) {
        await subscribeToStripeData(accountId, 'balances');
      }

      // Subscribe to transaction updates
      if (account.permissions?.includes('transactions')) {
        await subscribeToStripeData(accountId, 'transactions');
      }

      savedAccounts.push(savedAccount);
    }

    return c.json({
      success: true,
      accountsLinked: savedAccounts.length,
      accounts: savedAccounts,
    });
  } catch (error) {
    console.error('Error saving accounts:', error);
    return c.json({ error: 'Failed to save accounts', details: error.message }, 500);
  }
});

async function subscribeToStripeData(accountId: string, feature: string): Promise<void> {
  await fetch(`https://api.stripe.com/v1/financial_connections/accounts/${accountId}/subscribe`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${STRIPE_SECRET_KEY}`,
      'Content-Type': 'application/x-www-form-urlencoded',
    },
    body: new URLSearchParams({
      'features[]': feature,
    }),
  });
}

// Webhook handler for Stripe Financial Connections events
app.post('/make-server-8c22500c/financial/stripe-webhook', async (c) => {
  try {
    const signature = c.req.header('stripe-signature');
    const body = await c.req.text();

    if (!signature || !STRIPE_WEBHOOK_SECRET) {
      return c.json({ error: 'Invalid webhook signature' }, 400);
    }

    // Parse webhook event (simplified - in production use Stripe's verification)
    const event = JSON.parse(body);

    // Store webhook event
    await db.saveProviderWebhook({
      provider: 'stripe',
      external_event_id: event.id,
      event_type: event.type,
      payload: event.data.object,
    });

    // Handle specific events
    switch (event.type) {
      case 'financial_connections.account.disconnected':
        await handleAccountDisconnected(event.data.object);
        break;

      case 'financial_connections.account.refreshed_balance':
        await handleBalanceRefresh(event.data.object);
        break;

      case 'financial_connections.account.refreshed_transactions':
        await handleTransactionRefresh(event.data.object);
        break;
    }

    return c.json({ received: true });
  } catch (error) {
    console.error('Webhook error:', error);
    return c.json({ error: error.message }, 400);
  }
});

async function handleAccountDisconnected(account: any): Promise<void> {
  await db.updateLinkedAccountState(account.id, 'disconnected');
}

async function handleBalanceRefresh(account: any): Promise<void> {
  const linkedAccount = await db.getLinkedAccountByExternalId('stripe', account.id);
  if (!linkedAccount) return;

  await db.saveBalanceSnapshot({
    linked_account_id: linkedAccount.id,
    available_balance_cents: account.balance?.available?.usd || 0,
    current_balance_cents: account.balance?.current?.usd || 0,
    currency_code: 'USD',
  });
}

async function handleTransactionRefresh(account: any): Promise<void> {
  const linkedAccount = await db.getLinkedAccountByExternalId('stripe', account.id);
  if (!linkedAccount) return;

  // Fetch transactions from Stripe
  const response = await fetch(
    `https://api.stripe.com/v1/financial_connections/transactions?account=${account.id}&limit=100`,
    {
      headers: {
        'Authorization': `Bearer ${STRIPE_SECRET_KEY}`,
      },
    }
  );

  const data = await response.json();

  if (data.data) {
    for (const txn of data.data) {
      await db.saveTransaction({
        linked_account_id: linkedAccount.id,
        provider: 'stripe',
        external_transaction_id: txn.id,
        amount_cents: txn.amount,
        currency_code: txn.currency?.toUpperCase() || 'USD',
        description: txn.description,
        transaction_date: new Date(txn.transacted_at * 1000).toISOString().split('T')[0],
        is_pending: txn.status === 'pending',
      });
    }
  }
}

